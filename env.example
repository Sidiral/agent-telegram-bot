# Telegram Bot Token — get it from @BotFather
# Token del bot Telegram — ottenilo da @BotFather
TELEGRAM_TOKEN=your_telegram_bot_token_here

# Your Telegram user ID (you will be the admin)
# Il tuo user ID Telegram (sarai l'admin)
ADMIN_ID=your_telegram_user_id_here

# LM Studio local server URL
# URL del server locale di LM Studio
LM_STUDIO_URL=http://localhost:1234/v1

# Tavily API key for web search — get it at https://tavily.com
# API key Tavily per la ricerca web — ottienila su https://tavily.com
TAVILY_API_KEY=your_tavily_api_key_here
